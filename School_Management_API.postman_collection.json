{
  "info": {
    "name": "School Management API",
    "description": "Postman collection for the School Management API. Add schools and list them sorted by proximity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Delhi Public School\",\n  \"address\": \"Sector 24, R.K. Puram, New Delhi, 110022\",\n  \"latitude\": 28.5636,\n  \"longitude\": 77.1721\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        }
      },
      "response": []
    },
    {
      "name": "Add School - Bangalore",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"National Public School\",\n  \"address\": \"Rajajinagar, Bangalore, 560010\",\n  \"latitude\": 12.9902,\n  \"longitude\": 77.5520\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        }
      },
      "response": []
    },
    {
      "name": "Add School - Mumbai",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ryan International School\",\n  \"address\": \"Goregaon East, Mumbai, 400063\",\n  \"latitude\": 19.1631,\n  \"longitude\": 72.8496\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        }
      },
      "response": []
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=28.7041&longitude=77.1025",
          "host": ["{{baseUrl}}"],
          "path": ["listSchools"],
          "query": [
            {
              "key": "latitude",
              "value": "28.7041"
            },
            {
              "key": "longitude",
              "value": "77.1025"
            }
          ]
        }
      },
      "response": []
    }
  ]
}
